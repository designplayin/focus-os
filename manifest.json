{
  "manifest_version": 3,
  "name": "FocusOS",
  "version": "0.3.0",
  "description": "Transform YouTube into a calm, search-first experience.",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png"
    },
    "default_title": "FocusOS",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/content.js"],
      "css": ["content/focus.css"],
      "run_at": "document_start"
    }
  ]
}
